# ============================
# DevOps Buddy — Environment Variables
# Copy this file to .env and fill in your values
# ============================

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub Personal Access Token (fallback if user doesn't provide one in UI)
GITHUB_TOKEN=

# PostgreSQL Connection String
DATABASE_URL=postgresql://postgres:password@localhost:5432/devops_buddy

# Server Port
PORT=3000

# Gemini Model to use
GEMINI_MODEL=gemini-1.5-pro

# Reflexive AI Loop settings
AI_MIN_ITERATIONS=2
AI_MAX_ITERATIONS=5
AI_CONFIDENCE_THRESHOLD=0.9

# RL Q-value thresholds
RL_HIGH_CONFIDENCE=0.8
RL_HINT_THRESHOLD=0.5

# GitHub webhook secret (for PR feedback events)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
